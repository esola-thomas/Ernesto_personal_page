---
import SectionHeading from "./SectionHeading.astro";
import { getTranslations, type Locale } from "../i18n/translations";

interface Offer {
  title: string;
  description: string;
}

interface Props {
  offers: Offer[];
  locale?: Locale;
}

const { offers, locale = 'en' } = Astro.props;
const t = getTranslations(locale);
---
<section id="ways-i-help" class="py-24">
  <div class="container section-grid">
    <SectionHeading
      eyebrow={t.headings.waysIHelpEyebrow}
      title={t.headings.waysIHelp}
      description={t.headings.waysIHelpDesc}
    />

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {offers.map((offer) => (
        <article class="bento-card flex flex-col gap-4 p-6">
          <h3 class="font-display text-lg font-semibold text-primary">{offer.title}</h3>
          <p class="text-sm text-muted">{offer.description}</p>
        </article>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="#contact" class="button-primary">
        {t.waysIHelp.startConversation}
      </a>
      <p class="mt-4 text-xs text-soft">{t.waysIHelp.disclaimer}</p>
    </div>
  </div>
</section>
