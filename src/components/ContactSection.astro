---
import { getTranslations, type Locale } from "../i18n/translations";

interface ContactData {
  email: string;
  calendly?: string;
  location?: string;
}

interface Props {
  contact: ContactData;
  locale?: Locale;
}

const { contact, locale = 'en' } = Astro.props;
const t = getTranslations(locale);

const intents = [
  { key: "huitzo", subject: "Huitzo — Let's discuss" },
  { key: "speaking", subject: "Speaking / Podcast Inquiry" },
  { key: "research", subject: "Research Collaboration" },
  { key: "advisory", subject: "Advisory / Strategic Discussion" },
  { key: "general", subject: "General Inquiry" },
];
---
<section id="contact" class="py-24">
  <div class="container section-grid">
    <div class="section-heading">
      <span class="eyebrow">{t.headings.contactEyebrow}</span>
      <h2>{t.headings.contact}</h2>
      <p class="max-w-2xl text-base text-muted">
        {t.headings.contactDesc}
      </p>
    </div>

    <div class="glass-panel grid gap-8 p-10 md:grid-cols-[1.25fr_1fr] md:items-start">
      <div class="space-y-6">
        <div class="space-y-2">
          <p class="text-sm uppercase tracking-[0.35em] text-soft">{t.contact.primaryContact}</p>
          <a href={`mailto:${contact.email}`} class="text-2xl font-semibold text-[color:var(--color-accent)]">
            {contact.email}
          </a>
        </div>
        <p class="text-sm text-muted">{t.contact.intentPrompt}</p>
        <div class="flex flex-wrap gap-2">
          {intents.map((intent) => (
            <a
              href={`mailto:${contact.email}?subject=${encodeURIComponent(intent.subject)}`}
              class="rounded-md border border-soft bg-overlay px-3 py-2 text-xs font-medium text-secondary transition-colors hover:border-[var(--color-accent)] hover:text-primary"
            >
              {t.contact.intents[intent.key as keyof typeof t.contact.intents]}
            </a>
          ))}
        </div>
        <div class="flex flex-wrap gap-4 pt-2">
          <a href={`mailto:${contact.email}`} class="button-primary" data-goatcounter-click="contact-send-email">
            {t.contact.sendEmail}
          </a>
          {contact.calendly && (
            <a
              href={contact.calendly}
              class="button-ghost"
              target="_blank"
              rel="noreferrer"
              data-goatcounter-click="contact-book-conversation"
            >
              {t.contact.bookConversation}
            </a>
          )}
        </div>
      </div>
      <div class="space-y-6 text-sm text-soft">
        {contact.location && (
          <div>
            <p class="uppercase tracking-[0.35em] text-xs text-soft">{t.contact.location}</p>
            <p class="mt-2 text-base text-secondary">{contact.location}</p>
          </div>
        )}
        <div>
          <p class="uppercase tracking-[0.35em] text-xs text-soft">{t.contact.availability}</p>
          <p class="mt-2 text-muted">
            {t.contact.availabilityText}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
