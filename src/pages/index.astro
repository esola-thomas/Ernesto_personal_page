---
import { getCollection, getEntry } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import Hero from "../components/Hero.astro";
import ExperienceTimeline from "../components/ExperienceTimeline.astro";
import ProjectsShowcase from "../components/ProjectsShowcase.astro";
import ContactSection from "../components/ContactSection.astro";
import SelectedProof from "../components/SelectedProof.astro";
import TrustStrip from "../components/TrustStrip.astro";
import WaysICanHelp from "../components/WaysICanHelp.astro";
import VideoHighlights from "../components/VideoHighlights.astro";
import StorySection from "../components/StorySection.astro";
import BeyondSection from "../components/BeyondSection.astro";

const siteMeta = await getEntry("site", "meta");

const experiences = (await getCollection("experience", ({ id }) => !id.startsWith("es/"))).sort(
  (a, b) => Number(b.data.start) - Number(a.data.start)
);

const parseTimeframe = (value: string) => {
  const years = value.match(/\d{4}/g);
  if (!years) return 0;
  const last = years[years.length - 1];
  return Number(last);
};

const projects = (await getCollection("projects", ({ id }) => !id.startsWith("es/")))
  .sort((a, b) => parseTimeframe(b.data.timeframe) - parseTimeframe(a.data.timeframe))
  .slice(0, 5);

const personalEntries = await getCollection("personal", ({ id }) => !id.startsWith("es/"));

const chapters = [
  {
    num: "01",
    years: "2015–2019",
    title: "First builds",
    text: "A calculator app at 13. A piano wired from 555 timers. A water-quality instrument after finding algae in the school supply. Building before feeling ready became the habit.",
    href: "/journey/",
    linkLabel: "The journey"
  },
  {
    num: "02",
    years: "2020–2025",
    title: "Research years",
    text: "Clarkson University: IEEE-published autonomous wheelchair, wearable vision for blind users, prosthetic control, capped by a post-quantum cryptography master's thesis.",
    href: "/research/",
    linkLabel: "Research & publications"
  },
  {
    num: "03",
    years: "2022–now",
    title: "Silicon at scale",
    text: "Verifying AI accelerator silicon at Microsoft: UVM environments, floating-point pipelines, and automation adopted across verification teams.",
    href: "#experience",
    linkLabel: "Experience"
  },
  {
    num: "04",
    years: "2025–now",
    title: "Founder",
    text: "Huitzo, the operating system for intelligence: self-hosted AI for regulated enterprises.",
    href: "/huitzo/",
    linkLabel: "Huitzo"
  }
];

const proofCards = [
  {
    title: "AI Accelerator Silicon · Microsoft",
    challenge: "Verify floating-point pipelines and coverage closure for next-gen AI chips.",
    result: "Built reusable UVM environments and automation adopted across the org.",
  },
  {
    title: "Huitzo · The Operating System for Intelligence",
    challenge: "Regulated enterprises can't ship sensitive data to third-party AI services.",
    result: "Building a self-hosted AI runtime that runs Intelligence Packs inside customer infrastructure.",
    href: "/huitzo"
  },
  {
    title: "Post-Quantum Secure File Transfer",
    challenge: "Protect file transfers against quantum computing threats.",
    result: "Published a PQ-secured protocol with blockchain auditability (arXiv).",
    href: "https://arxiv.org/html/2504.07938v1"
  },
  {
    title: "Autonomous Wheelchair Platform",
    challenge: "Enable hands-free indoor navigation for mobility-impaired users.",
    result: "Published at IEEE: low-cost, open-source design with dual control modes.",
    href: "https://ieeexplore.ieee.org/abstract/document/9476093"
  },
  {
    title: "Cloud-Native Platform Ops",
    challenge: "Ship production-grade billing and auth for multi-tenant SaaS.",
    result: "Automated CI/CD pipelines enabling weekly iteration with confidence.",
  }
];

const offers = [
  {
    title: "Technical due diligence",
    description: "Evaluate architecture, code quality, and scalability risks for investment decisions or acquisition targets."
  },
  {
    title: "Prototype & system architecture",
    description: "Design and build proof-of-concept systems spanning hardware, firmware, cloud, and AI pipelines."
  },
  {
    title: "AI + hardware systems strategy",
    description: "Advise on AI accelerator integration, silicon-software co-design, and intelligent infrastructure planning."
  },
  {
    title: "Product & engineering advisory",
    description: "Help early-stage teams make high-leverage technical decisions, from stack selection to team structure."
  },
  {
    title: "Early-stage technical direction",
    description: "Partner with founders to translate vision into architecture, roadmap, and first working system."
  }
];

const videoHighlights = [
  {
    title: "Autonomous Wheelchair Platform",
    description: "A low-cost, open-source autonomous wheelchair built on a standard manual chair. Demonstrated hands-free indoor navigation using stereo depth camera, LiDAR, and Nvidia Jetson. Published at IEEE.",
    timeframe: "2021",
    youtubeId: "F6w_CqB0bZM",
    href: "https://youtu.be/F6w_CqB0bZM"
  },
  {
    title: "NBI EMG Prosthetic Hand",
    description: "A prosthetic hand driven by EMG muscle signals. The system translates electrical muscle activity into multi-grip actuation, restoring confidence and capability through biofeedback.",
    timeframe: "2021",
    youtubeId: "ThzdBNYLVCs",
    href: "https://www.youtube.com/watch?v=ThzdBNYLVCs"
  },
  {
    title: "Schumilop Water Quality Monitor",
    description: "A science fair project born from discovering algae in the school water supply. Combined electrolysis and sensor electronics to build a working water quality detection instrument.",
    timeframe: "2019",
    youtubeId: "V4YPrQcctF0",
    href: "https://www.youtube.com/watch?v=V4YPrQcctF0"
  }
];
---
<SiteLayout
  title="Ernesto Sola-Thomas • Silicon Engineer & Founder"
  description="Ernesto Sola-Thomas: founder of Huitzo, the self-hosted AI runtime for regulated enterprises, and silicon verification engineer at Microsoft."
  siteMeta={siteMeta}
  locale="en"
>
  <Hero hero={siteMeta.data.hero} quickFacts={siteMeta.data.quickFacts} locale="en" />
  <TrustStrip locale="en" />
  <div data-reveal>
    <StorySection chapters={chapters} locale="en" />
  </div>
  <div data-reveal>
    <ExperienceTimeline entries={experiences} locale="en" />
  </div>
  <div data-reveal>
    <SelectedProof cards={proofCards} locale="en" />
  </div>
  <div data-reveal>
    <ProjectsShowcase entries={projects} locale="en" />
  </div>
  <div data-reveal>
    <VideoHighlights videos={videoHighlights} locale="en" />
  </div>
  <div data-reveal>
    <WaysICanHelp offers={offers} locale="en" />
  </div>
  <div data-reveal>
    <BeyondSection entries={personalEntries} locale="en" />
  </div>
  <div data-reveal>
    <ContactSection contact={siteMeta.data.contact} locale="en" />
  </div>
</SiteLayout>
