---
import { getCollection, getEntry } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import Hero from "../../components/Hero.astro";
import ExperienceTimeline from "../../components/ExperienceTimeline.astro";
import ProjectsShowcase from "../../components/ProjectsShowcase.astro";
import ContactSection from "../../components/ContactSection.astro";
import AchievementsSection from "../../components/AchievementsSection.astro";
import SelectedProof from "../../components/SelectedProof.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import WaysICanHelp from "../../components/WaysICanHelp.astro";
import VideoHighlights from "../../components/VideoHighlights.astro";
import Reveal from "../../components/motion/Reveal.tsx";

const siteMeta = await getEntry("site", "es/meta");

const experiences = (await getCollection("experience", ({ id }) => id.startsWith("es/"))).sort(
  (a, b) => Number(b.data.start) - Number(a.data.start)
);

const parseTimeframe = (value: string) => {
  const years = value.match(/\d{4}/g);
  if (!years) return 0;
  const last = years[years.length - 1];
  return Number(last);
};

const projects = (await getCollection("projects", ({ id }) => id.startsWith("es/")))
  .sort((a, b) => parseTimeframe(b.data.timeframe) - parseTimeframe(a.data.timeframe))
  .slice(0, 5);

const achievements = [
  {
    title: "Verificación de silicio",
    description: "Construyendo entornos de prueba UVM reutilizables para RTL en Microsoft, cubriendo pipelines de punto flotante, pruebas aleatorias restringidas y automatización de cobertura."
  },
  {
    title: "IA y sistemas de hardware",
    description: "Verificación de silicio para aceleradores de IA y arquitecturas a nivel de chip, abarcando métodos formales, cobertura funcional y diseño listo para síntesis."
  },
  {
    title: "Infraestructura cloud",
    description: "Desplegando plataformas de grado producción con Kubernetes, Docker, Terraform y pipelines CI/CD para emprendimientos personales y clientes."
  },
  {
    title: "Investigación aplicada",
    description: "Criptografía post-cuántica, robótica asistiva y neurotecnología — traduciendo investigación académica en prototipos funcionales."
  }
];

const proofCards = [
  {
    title: "Silicio para Acelerador de IA — Microsoft",
    challenge: "Verificar pipelines de punto flotante y cierre de cobertura para chips de IA.",
    result: "Entornos UVM reutilizables y automatización adoptados en toda la organización.",
  },
  {
    title: "Huitzo — Inteligencia como Servicio",
    challenge: "Hacer capacidades avanzadas de IA accesibles para empresas y startups.",
    result: "Diseñando infraestructura de IA escalable con pipelines de datos modulares.",
    href: "/huitzo"
  },
  {
    title: "Transferencia Segura Post-Cuántica",
    challenge: "Proteger transferencias de archivos contra amenazas de computación cuántica.",
    result: "Protocolo PQ publicado con auditabilidad blockchain (arXiv).",
    href: "https://arxiv.org/html/2504.07938v1"
  },
  {
    title: "Plataforma de Silla de Ruedas Autónoma",
    challenge: "Habilitar navegación autónoma en interiores para usuarios con movilidad reducida.",
    result: "Publicado en IEEE — diseño open-source de bajo costo con modos de control dual.",
    href: "https://ieeexplore.ieee.org/abstract/document/9476093"
  },
  {
    title: "Operaciones de Plataforma Cloud-Native",
    challenge: "Enviar facturación y autenticación para SaaS multi-tenant.",
    result: "Pipelines CI/CD automatizados para iteración semanal con confianza.",
  }
];

const offers = [
  {
    title: "Due diligence técnico",
    description: "Evaluar arquitectura, calidad de código y riesgos de escalabilidad para decisiones de inversión o adquisición."
  },
  {
    title: "Prototipo y arquitectura de sistemas",
    description: "Diseñar y construir sistemas de prueba de concepto que abarcan hardware, firmware, cloud y pipelines de IA."
  },
  {
    title: "Estrategia de IA + sistemas de hardware",
    description: "Asesorar en integración de aceleradores de IA, co-diseño silicio-software y planificación de infraestructura inteligente."
  },
  {
    title: "Asesoría de producto e ingeniería",
    description: "Ayudar a equipos en etapa temprana a tomar decisiones técnicas de alto impacto — desde selección de stack hasta estructura de equipo."
  },
  {
    title: "Dirección técnica temprana",
    description: "Acompañar a fundadores para traducir visión en arquitectura, roadmap y primer sistema funcional."
  }
];

const videoHighlights = [
  {
    title: "Plataforma de Silla de Ruedas Autónoma",
    description: "Una silla de ruedas autónoma de bajo costo y código abierto construida sobre una silla manual estándar. Demostró navegación autónoma sin manos en interiores usando cámara de profundidad estéreo, LiDAR y Nvidia Jetson. Publicada en IEEE.",
    timeframe: "2021",
    youtubeId: "F6w_CqB0bZM",
    href: "https://youtu.be/F6w_CqB0bZM"
  },
  {
    title: "Mano Protésica EMG NBI",
    description: "Una mano protésica accionada por señales musculares EMG. El sistema traduce la actividad eléctrica muscular en actuación multi-agarre, restaurando confianza y capacidad a través de biofeedback.",
    timeframe: "2021",
    youtubeId: "ThzdBNYLVCs",
    href: "https://www.youtube.com/watch?v=ThzdBNYLVCs"
  },
  {
    title: "Monitor de Calidad del Agua Schumilop",
    description: "Proyecto de feria de ciencias nacido al descubrir algas en el suministro de agua escolar. Combinó electrólisis y electrónica de sensores para construir un instrumento de detección de calidad del agua.",
    timeframe: "2019",
    youtubeId: "V4YPrQcctF0",
    href: "https://www.youtube.com/watch?v=V4YPrQcctF0"
  }
];
---
<SiteLayout
  title="Ernesto Sola-Thomas • Ingeniero de Silicio y Fundador"
  description="Ernesto Sola-Thomas — fundador de Huitzo (plataforma de inteligencia IA) e ingeniero de verificación de silicio en Microsoft. Profundidad técnica, convicción fundadora."
  siteMeta={siteMeta}
  locale="es"
>
  <Hero hero={siteMeta.data.hero} quickFacts={siteMeta.data.quickFacts} locale="es" />
  <TrustStrip locale="es" />
  <Reveal client:visible>
    <SelectedProof cards={proofCards} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <AchievementsSection achievements={achievements} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <ExperienceTimeline entries={experiences} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <WaysICanHelp offers={offers} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <ProjectsShowcase entries={projects} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <VideoHighlights videos={videoHighlights} locale="es" />
  </Reveal>
  <Reveal client:visible>
    <ContactSection contact={siteMeta.data.contact} locale="es" />
  </Reveal>
</SiteLayout>
