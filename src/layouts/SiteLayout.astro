---
import "../styles/global.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

import type { CollectionEntry } from "astro:content";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    dateModified?: string;
    image: string;
  };
  siteMeta?: CollectionEntry<"site">;
  locale?: string;
}

const {
  title = "Ernesto Sola-Thomas • Silicon Engineer & Founder",
  description = "Ernesto Sola-Thomas: silicon verification engineer at Microsoft, founder of Huitzo, and IEEE-published researcher building human-centered technology.",
  ogImage = new URL("og-default.png", Astro.site).href,
  ogType = "website",
  article,
  siteMeta,
  locale = "en"
} = Astro.props as Props;

// Per-page hreflang pair: /es/foo/ <-> /foo/
const path = Astro.url.pathname;
const isSpanish = path === "/es" || path.startsWith("/es/");
const enPath = isSpanish ? path.replace(/^\/es\/?/, "/") : path;
const esPath = isSpanish ? path : `/es${path === "/" ? "/" : path}`;
const enUrl = new URL(enPath, Astro.site).href;
const esUrl = new URL(esPath, Astro.site).href;
const isHome = enPath === "/";

const personId = `${Astro.site}#person`;
const hero = siteMeta?.data.hero;
const contact = siteMeta?.data.contact;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      url: `${Astro.site}`,
      name: "Ernesto Sola-Thomas",
      description,
      inLanguage: ["en", "es"],
      publisher: { "@id": personId }
    },
    ...(isHome
      ? [
          {
            "@type": "ProfilePage",
            "@id": `${Astro.url.href}#profilepage`,
            url: Astro.url.href,
            name: title,
            mainEntity: { "@id": personId }
          }
        ]
      : []),
    ...(article
      ? [
          {
            "@type": "BlogPosting",
            "@id": `${Astro.url.href}#article`,
            mainEntityOfPage: Astro.url.href,
            headline: article.headline,
            description: article.description,
            datePublished: article.datePublished,
            dateModified: article.dateModified ?? article.datePublished,
            author: { "@id": personId },
            publisher: { "@id": personId },
            inLanguage: locale,
            image: article.image
          }
        ]
      : []),
    {
      "@type": "Person",
      "@id": personId,
      name: hero?.name ?? "Ernesto Sola-Thomas",
      givenName: "Ernesto",
      familyName: "Sola-Thomas",
      jobTitle: hero?.title ?? "Silicon Engineer · Founder",
      url: `${Astro.site}`,
      image: new URL("images/ernesto-sola-thomas.jpg", Astro.site).href,
      email: contact?.email ?? "ernesto@solathomas.com",
      sameAs: [
        "https://github.com/esola-thomas",
        "https://www.linkedin.com/in/sola-thomas",
        "https://ieeexplore.ieee.org/author/37088854705"
      ],
      knowsAbout: [
        "Silicon Verification",
        "Hardware Verification",
        "SystemVerilog",
        "UVM",
        "FPGA Development",
        "AI Accelerators",
        "Post-Quantum Cryptography",
        "Blockchain Technology",
        "Cloud Architecture",
        "Kubernetes",
        "Python",
        "Embedded Systems",
        "Assistive Robotics"
      ],
      knowsLanguage: ["en", "es"],
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Clarkson University",
        address: { "@type": "PostalAddress", addressLocality: "Potsdam", addressRegion: "NY" }
      },
      worksFor: { "@type": "Organization", name: "Microsoft" },
      address: {
        "@type": "PostalAddress",
        addressLocality: "Raleigh",
        addressRegion: "NC"
      }
    },
    {
      "@type": "Organization",
      "@id": `${Astro.site}#huitzo`,
      name: "Huitzo",
      url: "https://huitzo.com",
      founder: { "@id": personId },
      foundingDate: "2025",
      description:
        "Self-hosted AI runtime, the operating system for intelligence, that lets regulated enterprises run AI applications inside their own infrastructure"
    },
    {
      "@type": "Organization",
      "@id": `${Astro.site}#sola-thomas-solutions`,
      name: "Sola-Thomas Solutions LLC",
      founder: { "@id": personId },
      foundingDate: "2025",
      description:
        "Consulting studio accelerating hardware-software prototypes, analytics platforms, and cloud automation"
    }
  ]
});
---
<!DOCTYPE html>
<html lang={locale} class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Ernesto Sola-Thomas" />
    <meta name="theme-color" content="#047857" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#00FF7F" media="(prefers-color-scheme: dark)" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" type="application/rss+xml" title="Ernesto Sola-Thomas: Writing" href="/rss.xml" />

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {article && <meta property="article:published_time" content={article.datePublished} />}
    {article && <meta property="article:modified_time" content={article.dateModified ?? article.datePublished} />}
    {article && <meta property="article:author" content="Ernesto Sola-Thomas" />}
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ernesto Sola-Thomas: Silicon Engineer, Founder, Builder" />
    <meta property="og:site_name" content="Ernesto Sola-Thomas" />
    <meta property="og:locale" content={locale === "es" ? "es_ES" : "en_US"} />
    <meta property="og:locale:alternate" content={locale === "es" ? "en_US" : "es_ES"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={jsonLd}></script>

    <script is:inline>
      (function () {
        document.documentElement.classList.add("js");
        try {
          const theme = window.localStorage.getItem("theme");
          if (theme === "light") {
            document.documentElement.classList.remove("dark");
          } else {
            document.documentElement.classList.add("dark");
          }
        } catch (err) {
          console.warn("Theme preference unavailable", err);
        }
      })();
    </script>

    <script data-goatcounter="https://ernessola.goatcounter.com/count"
        async src="//gc.zgo.at/count.js"></script>
  </head>
  <body class="flex min-h-dvh flex-col">
    <div class="scroll-progress" aria-hidden="true"></div>
    <Header locale={locale} />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} disclaimer={siteMeta?.data.disclaimer} />
    <script type="module" src="/theme-toggle.js" defer></script>
    <script is:inline>
      (function () {
        const targets = document.querySelectorAll("[data-reveal]");
        if (!targets.length || !("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("in-view"));
          return;
        }
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.1, rootMargin: "0px 0px -48px 0px" }
        );
        targets.forEach((el) => observer.observe(el));
      })();
    </script>
  </body>
</html>
